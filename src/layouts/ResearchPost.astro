---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  status: 'Draft' | 'In Progress' | 'Published';
  abstract: string;
  tags: string[];
}

const { title, date, status, abstract, tags } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const badgeClass = {
  'Draft': 'badge-draft',
  'In Progress': 'badge-in-progress',
  'Published': 'badge-published',
}[status];
---

<Base title={title}>
  <article>
    <header class="post-header">
      <div class="top-meta">
        <span class={`badge ${badgeClass}`}>{status}</span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
      <h1>{title}</h1>
      <blockquote class="abstract">{abstract}</blockquote>
      <div class="tags">
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    </header>
    <hr />
    <div class="prose">
      <slot />
    </div>
    <hr />
    <a href="/research" class="back-link">← Back to Research</a>
  </article>
</Base>

<style>
  article {
    padding-top: 40px;
    padding-bottom: 48px;
  }

  .post-header {
    margin-bottom: 1.5rem;
  }

  .top-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 12px;
  }

  time {
    font-size: 12px;
    color: var(--text-tertiary);
    font-family: var(--font-sans);
  }

  h1 {
    font-size: 28px;
    margin-bottom: 16px;
    line-height: 1.2;
    color: var(--text-primary);
  }

  .abstract {
    border-left: 3px solid var(--color-accent);
    padding: 12px 16px;
    margin: 0 0 16px;
    background: var(--color-accent-light);
    border-radius: 0 6px 6px 0;
    font-style: italic;
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .back-link {
    font-size: 13px;
    color: var(--text-secondary);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 22px;
    }
  }
</style>
