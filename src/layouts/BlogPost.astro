---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  readTime: number;
  tags: string[];
}

const { title, date, readTime, tags } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={title}>
  <article>
    <header class="post-header">
      <div class="meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="dot">·</span>
        <span>{readTime} min read</span>
      </div>
      <h1>{title}</h1>
      <div class="tags">
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    </header>
    <hr />
    <div class="prose">
      <slot />
    </div>
    <hr />
    <a href="/essays" class="back-link">← Back to Essays</a>
  </article>
</Base>

<style>
  article {
    padding-top: 40px;
    padding-bottom: 48px;
  }

  .post-header {
    margin-bottom: 1.5rem;
  }

  .meta {
    font-size: 12px;
    color: var(--text-tertiary);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
  }

  .dot {
    opacity: 0.4;
  }

  h1 {
    font-size: 28px;
    margin-bottom: 16px;
    line-height: 1.2;
    color: var(--text-primary);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .back-link {
    font-size: 13px;
    color: var(--text-secondary);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 22px;
    }
  }
</style>
