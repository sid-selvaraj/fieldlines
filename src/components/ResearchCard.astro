---
interface Props {
  title: string;
  date: Date;
  status: 'Draft' | 'In Progress' | 'Published';
  abstract: string;
  tags: string[];
  slug: string;
}

const { title, date, status, abstract, tags, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const badgeClass = {
  'Draft': 'badge-draft',
  'In Progress': 'badge-in-progress',
  'Published': 'badge-published',
}[status];
---

<article>
  <div class="card-type">Research Note</div>
  <div class="header">
    <span class={`badge ${badgeClass}`}>{status}</span>
    <time datetime={date.toISOString()}>{formattedDate}</time>
  </div>
  <h3>
    <a href={`/research/${slug}`}>{title}</a>
  </h3>
  <p class="abstract">{abstract}</p>
  <div class="tags">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</article>

<style>
  article {
    background: var(--card-bg);
    border: 1px solid var(--border-card);
    border-left: 3px solid var(--color-accent);
    border-radius: 10px;
    padding: 20px;
    transition: border-color 0.15s;
    margin-bottom: 12px;
  }

  article:hover {
    border-color: var(--color-accent);
  }

  .card-type {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 8px;
    font-family: var(--font-sans);
    font-weight: 500;
  }

  .header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 8px;
  }

  time {
    font-size: 11px;
    color: var(--text-tertiary);
  }

  h3 {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 15px;
    color: var(--text-primary);
    line-height: 1.4;
    font-weight: 400;
    margin-bottom: 8px;
  }

  h3 a {
    color: var(--text-primary);
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--color-accent);
  }

  .abstract {
    font-size: 12px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
