---
interface Props {
  title: string;
  date: Date;
  readTime: number;
  tags: string[];
  slug: string;
}

const { title, date, readTime, tags, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article>
  <div class="card-type">Essay</div>
  <div class="meta">
    <time datetime={date.toISOString()}>{formattedDate}</time>
    <span class="dot">·</span>
    <span>{readTime} min read</span>
  </div>
  <h3>
    <a href={`/essays/${slug}`}>{title}</a>
  </h3>
  <div class="tags">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</article>

<style>
  article {
    background: var(--card-bg);
    border: 1px solid var(--border-card);
    border-left: 3px solid transparent;
    border-radius: 10px;
    padding: 20px;
    transition: border-color 0.15s;
    margin-bottom: 12px;
  }

  article:hover {
    border-left-color: var(--color-accent);
  }

  .card-type {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 8px;
    font-family: var(--font-sans);
    font-weight: 500;
  }

  .meta {
    font-size: 11px;
    color: var(--text-tertiary);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .dot {
    opacity: 0.5;
  }

  h3 {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 15px;
    color: var(--text-primary);
    line-height: 1.4;
    font-weight: 400;
    margin-bottom: 10px;
  }

  h3 a {
    color: var(--text-primary);
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--color-accent);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
