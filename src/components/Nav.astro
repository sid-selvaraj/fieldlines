---
const navLinks = [
  { href: '/research', label: 'Research' },
  { href: '/essays', label: 'Essays' },
  { href: '/simulations', label: 'Simulations' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header>
  <nav>
    <a href="/" class="logo">
      Siddharth Selvaraj <span class="divider">·</span> Particle Physics
    </a>
    <ul>
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[{ active: currentPath === link.href || currentPath.startsWith(link.href + '/') }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border-color);
    background: var(--page-bg);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  nav {
    max-width: 720px;
    margin: 0 auto;
    padding: 18px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .logo:hover {
    text-decoration: none;
    color: var(--color-accent);
  }

  .divider {
    color: var(--color-accent-mid);
    margin: 0 0.15em;
    opacity: 0.6;
  }

  ul {
    list-style: none;
    display: flex;
    gap: 2rem;
    flex-shrink: 0;
  }

  ul a {
    font-size: 12px;
    color: var(--text-tertiary);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  ul a:hover,
  ul a.active {
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 580px) {
    nav {
      padding: 16px 20px;
    }

    .logo {
      font-size: 12px;
    }

    ul {
      gap: 1.25rem;
    }
  }
</style>
