---
import Base from '../../layouts/Base.astro';
import SimCard from '../../components/SimCard.astro';

const simulations = [
  {
    title: 'Double-Slit Experiment',
    description:
      'Interactive wave-particle duality simulation with adjustable slit separation and wavelength.',
    href: '/simulations/double-slit',
  },
  {
    title: 'Electric Field Visualizer',
    description: 'Place charges and watch field lines emerge in real time.',
    href: '/simulations/electric-field',
  },
  {
    title: 'Particle Physics Explorer',
    description:
      'Explore the Standard Model, drag particles into Feynman diagrams, and quiz yourself on the fundamental building blocks of matter.',
    href: '/simulations/particle-physics',
  },
];
---

<Base title="Simulations">
  <div class="page-header">
    <h1>Simulations</h1>
    <p>
      Interactive physics simulations built to develop intuition about quantum and classical
      phenomena.
    </p>
  </div>

  <h2 class="section-label">All Simulations</h2>
  <div class="grid">
    {simulations.map(sim => (
      <SimCard title={sim.title} description={sim.description} href={sim.href} />
    ))}
  </div>
</Base>

<style>
  .page-header {
    padding-top: 40px;
    margin-bottom: 32px;
  }

  h1 {
    font-size: 28px;
    margin-bottom: 8px;
    color: var(--text-primary);
  }

  p {
    font-size: 14px;
    color: var(--text-secondary);
    max-width: 520px;
    line-height: 1.6;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    padding-bottom: 48px;
  }
</style>
