---
import Base from '../../layouts/Base.astro';
---

<Base title="Electric Field Visualizer">
  <article>
    <a href="/simulations" class="back">← Simulations</a>
    <h1>Electric Field Visualizer</h1>
    <p class="desc">Place charges and watch field lines emerge in real time.</p>
    <hr />
    <div class="placeholder">
      <p class="label">Simulation in progress</p>
      <p class="note">
        I'm building a Canvas-based electric field visualizer where you can place positive and
        negative point charges on a plane and watch the field lines and equipotential contours
        render dynamically. The math uses superposition of Coulomb fields.
      </p>
    </div>
  </article>
</Base>

<style>
  .back {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
    text-decoration: none;
  }

  .back:hover {
    color: var(--color-accent);
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .desc {
    color: var(--color-text-secondary);
    max-width: 520px;
  }

  .placeholder {
    background: var(--color-bg-secondary);
    border: 1px dashed var(--color-border);
    border-radius: 4px;
    padding: 3.5rem 2rem;
    text-align: center;
  }

  .label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .note {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    max-width: 460px;
    margin: 0 auto;
    line-height: 1.7;
  }
</style>
