---
import Base from '../layouts/Base.astro';
import ResearchCard from '../components/ResearchCard.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const journal = await getCollection('journal');
journal.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestJournal = journal[0];

const research = await getCollection('research');
const essays = await getCollection('essays');

research.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
essays.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latestResearch = research[0];
const latestEssay = essays[0];

type RecentEntry = {
  type: 'research' | 'essay';
  title: string;
  date: Date;
  slug: string;
};

const recentEntries: RecentEntry[] = [
  ...research.map(r => ({ type: 'research' as const, title: r.data.title, date: r.data.date, slug: r.id })),
  ...essays.map(e => ({ type: 'essay' as const, title: e.data.title, date: e.data.date, slug: e.id })),
]
  .sort((a, b) => b.date.valueOf() - a.date.valueOf())
  .slice(0, 5);
---

<Base title="Home">
  <!-- Hero -->
  <section class="hero">
    <canvas id="particle-canvas"></canvas>
    <div class="hero-inner">
      <p class="eyebrow">Particle Physics · Edison, NJ</p>
      <h1>Siddharth Selvaraj</h1>
      <p class="sub-text">
        I'm a high school student fascinated by particle physics and the mathematics that underpins
        the universe. This is where I document my research, ideas, and simulations.
      </p>
      <div class="hero-tags">
        <span class="hero-tag">9th Grade</span>
        <span class="hero-tag">Special Relativity</span>
        <span class="hero-tag">Standard Model</span>
      </div>
    </div>
  </section>

  <!-- Featured two-column -->
  <section class="featured">
    <div class="featured-col">
      <h2 class="section-label">Latest Research</h2>
      {latestResearch && (
        <ResearchCard
          title={latestResearch.data.title}
          date={latestResearch.data.date}
          status={latestResearch.data.status}
          abstract={latestResearch.data.abstract}
          tags={latestResearch.data.tags}
          slug={latestResearch.id}
        />
      )}
      <a href="/research" class="see-all">All research notes →</a>
    </div>
    <div class="featured-col">
      <h2 class="section-label">Latest Essay</h2>
      {latestEssay && (
        <PostCard
          title={latestEssay.data.title}
          date={latestEssay.data.date}
          readTime={latestEssay.data.readTime}
          tags={latestEssay.data.tags}
          slug={latestEssay.id}
        />
      )}
      <a href="/essays" class="see-all">All essays →</a>
    </div>
  </section>

  <!-- Recent entries -->
  <section class="recent">
    <h2 class="section-label">Recent entries</h2>
    <ol class="entries-list">
      {recentEntries.map((entry, i) => (
        <li>
          <span class="entry-num">{String(i + 1).padStart(2, '0')}</span>
          <a
            class="entry-title"
            href={`/${entry.type === 'research' ? 'research' : 'essays'}/${entry.slug}`}
          >
            {entry.title}
          </a>
          <span class="entry-type-tag">{entry.type}</span>
          <span class="entry-date">
            {entry.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
          </span>
        </li>
      ))}
    </ol>
  </section>

  <!-- Field Journal teaser -->
  {latestJournal && (
    <section class="journal-teaser">
      <h2 class="section-label">Field Journal</h2>
      <a href={`/journal/${latestJournal.id}`} class="journal-card">
        {latestJournal.data.heroImage && (
          <img
            src={latestJournal.data.heroImage}
            alt={latestJournal.data.title}
            class="journal-thumb"
          />
        )}
        <div class="journal-card-body">
          <span class="journal-card-label">Field Journal</span>
          <p class="journal-card-title">{latestJournal.data.title}</p>
          <p class="journal-card-meta">
            {latestJournal.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </p>
          {latestJournal.data.award && (
            <span class="journal-card-badge">{latestJournal.data.award}</span>
          )}
        </div>
      </a>
    </section>
  )}

  <!-- Feynman quote -->
  <blockquote class="quote">
    <p>
      "The first principle is that you must not fool yourself — and you are the easiest person to
      fool."
    </p>
    <footer>— Richard Feynman · A guiding principle for this site</footer>
  </blockquote>
</Base>

<script>
  const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    let particles: { x: number; y: number; vx: number; vy: number }[] = [];

    function resize() {
      const hero = canvas!.parentElement!;
      canvas!.width = hero.offsetWidth;
      canvas!.height = hero.offsetHeight;
    }

    function initParticles() {
      particles = Array.from({ length: 22 }, () => {
        const angle = Math.random() * Math.PI * 2;
        return {
          x: Math.random() * canvas!.width,
          y: Math.random() * canvas!.height,
          vx: Math.cos(angle) * 0.4,
          vy: Math.sin(angle) * 0.4,
        };
      });
    }

    function draw() {
      ctx.clearRect(0, 0, canvas!.width, canvas!.height);

      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > canvas!.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas!.height) p.vy *= -1;

        ctx.beginPath();
        ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(127,119,221,0.5)';
        ctx.fill();

        for (let j = i + 1; j < particles.length; j++) {
          const q = particles[j];
          const dx = p.x - q.x;
          const dy = p.y - q.y;
          if (dx * dx + dy * dy < 110 * 110) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(q.x, q.y);
            ctx.strokeStyle = 'rgba(127,119,221,0.18)';
            ctx.lineWidth = 1;
            ctx.stroke();
          }
        }
      }

      requestAnimationFrame(draw);
    }

    resize();
    initParticles();
    draw();

    window.addEventListener('resize', () => {
      resize();
      initParticles();
    });
  }
</script>

<style>
  /* Hero — full-bleed breakout from main container */
  .hero {
    background: var(--hero-bg);
    border-bottom: 1px solid var(--border-color);
    padding: 0;
    position: relative;
    overflow: hidden;
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }

  #particle-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 40px 48px;
  }

  .eyebrow {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: 16px;
    line-height: 1;
    font-family: var(--font-sans);
  }

  .hero-inner h1 {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 38px;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    max-width: 480px;
    margin-bottom: 16px;
  }

  .sub-text {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 420px;
    margin-bottom: 28px;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .hero-tag {
    border: 1px solid var(--border-card);
    border-radius: 20px;
    padding: 4px 12px;
    font-size: 11px;
    color: var(--text-tertiary);
    background: var(--page-bg);
    font-family: var(--font-sans);
  }

  /* Featured */
  .featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    padding: 40px 0 8px;
  }

  .see-all {
    display: inline-block;
    margin-top: 12px;
    font-size: 12px;
    color: var(--color-accent);
    text-decoration: none;
  }

  .see-all:hover {
    text-decoration: underline;
  }

  /* Recent entries */
  .recent {
    padding: 32px 0 8px;
  }

  .entries-list {
    list-style: none;
  }

  .entries-list li {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 13px 0;
    border-bottom: 1px solid #f0f0ec;
  }

  .entries-list li:hover .entry-title {
    color: var(--color-accent);
  }

  .entry-num {
    font-size: 11px;
    color: var(--text-tertiary);
    min-width: 20px;
    font-variant-numeric: tabular-nums;
    font-family: var(--font-mono);
    flex-shrink: 0;
  }

  .entry-title {
    font-size: 13px;
    color: var(--text-secondary);
    flex: 1;
    line-height: 1.4;
    text-decoration: none;
    transition: color 0.15s;
  }

  .entry-type-tag {
    font-size: 11px;
    padding: 2px 8px;
    background: #EEEDFE;
    color: #7F77DD;
    border-radius: 10px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .entry-date {
    font-size: 11px;
    color: var(--text-tertiary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Field Journal teaser */
  .journal-teaser {
    padding: 32px 0 8px;
  }

  .journal-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 16px;
    border: 1px solid var(--border-card);
    border-radius: 10px;
    background: var(--card-bg);
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .journal-card:hover {
    border-color: var(--color-accent);
  }

  .journal-thumb {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .journal-card-body {
    flex: 1;
    min-width: 0;
  }

  .journal-card-label {
    font-size: 10px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-family: var(--font-sans);
    font-weight: 500;
    display: block;
    margin-bottom: 4px;
  }

  .journal-card-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.4;
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .journal-card-meta {
    font-size: 11px;
    color: var(--text-tertiary);
    margin-bottom: 6px;
  }

  .journal-card-badge {
    font-size: 11px;
    padding: 2px 8px;
    background: #EEEDFE;
    color: #7F77DD;
    border-radius: 10px;
  }

  /* Quote */
  .quote {
    border-left: 3px solid var(--color-accent);
    padding: 16px 20px;
    background: var(--color-accent-light);
    border-radius: 0 8px 8px 0;
    margin-top: 40px;
    margin-bottom: 48px;
  }

  .quote p {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    font-style: italic;
    margin-bottom: 8px;
  }

  .quote footer {
    font-size: 11px;
    color: var(--text-tertiary);
  }

  @media (max-width: 680px) {
    .hero-inner {
      padding: 40px 24px 36px;
    }

    .hero-inner h1 {
      font-size: 28px;
    }

    .featured {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .entry-type-tag,
    .entry-date {
      display: none;
    }
  }
</style>
