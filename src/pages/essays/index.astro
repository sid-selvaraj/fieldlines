---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('essays');
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Essays">
  <div class="page-header">
    <h1>Essays</h1>
    <p>
      Longer-form writing on physics concepts, ideas I find fascinating, and lessons I've learned
      while studying.
    </p>
  </div>

  <h2 class="section-label">All Essays</h2>
  <div class="list">
    {posts.map(post => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        readTime={post.data.readTime}
        tags={post.data.tags}
        slug={post.id}
      />
    ))}
  </div>
</Base>

<style>
  .page-header {
    padding-top: 40px;
    margin-bottom: 32px;
  }

  h1 {
    font-size: 28px;
    margin-bottom: 8px;
    color: var(--text-primary);
  }

  p {
    font-size: 14px;
    color: var(--text-secondary);
    max-width: 520px;
    line-height: 1.6;
  }
</style>
